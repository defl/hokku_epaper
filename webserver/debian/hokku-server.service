[Unit]
Description=Hokku Spectra 6 image server
After=network.target
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
Type=simple
ExecStart=/usr/bin/hokku-server /var/lib/hokku/config.json
Environment="PYTHONUNBUFFERED=1"
DynamicUser=yes
StateDirectory=hokku
CacheDirectory=hokku
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
